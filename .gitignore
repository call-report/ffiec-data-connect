# IDE and editor settings
.vscode/
.idea/

# AI assistants / developer tooling (per-user state — never commit)
.claude/
.cursor/
.continue/
.aider*

# Virtual environments
.venv/
venv/
env/

# Python bytecode and cache
*.pyc
*__pycache__*
.mypy_cache/
.ruff_cache/

# uv lockfile — libraries should not ship lockfiles (applications do)
uv.lock

# OS files
.DS_Store
Thumbs.db

# Testing and coverage
.pytest_cache/
.pytest_cache.coverage
htmlcov/
coverage.xml
coverage.json
*.coverage

# Build artifacts and documentation
docs/build/
build/
dist/
*.egg-info/

# Test output files - prevent accidental commit of sensitive data
ffiec_data_*.csv
ffiec_data_*.xlsx
ffiec_data_*.parquet
ffiec_data_*.json
ffiec_data_*.png
rest_api_response_data.json

# Debug and test scripts with potential credentials (root only, not tests/)
/test_*.py
/collect_*.py
/*_debug.py
/*_test.py

# Internal documentation - prevent accidental commit
*_IMPLEMENTATION_*.md
*_GUIDE_*.md
*_RELEASE_*.md
*_MAPPING.md
*_FIXES.md

# Claude Code
CLAUDE.md

# Temporary files
*.tmp
*.temp
.env
.env.local
